# 复制为 .env 并填入真实值；.env 已被 .gitignore 忽略，切勿提交。
# 数据库 root 密码（SQL_DSN 和 MYSQL_ROOT_PASSWORD 必须一致）
DB_PASSWORD=change_me_to_a_strong_password
# 会话密钥，建议用随机字符串：openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_secret
# 监听 IP（如只本机 127.0.0.1，对外可留空表示 0.0.0.0）
HOST_IP=
# 对外端口
WEB_HTTP_PORT=3000
# 数据/日志/mysql 挂载根目录
APP_PATH=/www/wwwroot/new-api
